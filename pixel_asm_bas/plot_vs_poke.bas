10 MODE 1:INK 1,18:CLS
20 PRINT "1. DIBUJANDO CON PLOT..."
30 t1=TIME:FOR y=0 TO 398 STEP 2:PLOT 320,y,1:NEXT:t2=TIME
40 PRINT "TIEMPO PLOT:";(t2-t1)/300;" SEGUNDOS"
50 PRINT "PULSA UNA TECLA PARA POKE"
60 CALL &BB18:CLS
70 PRINT "2. DIBUJANDO CON POKE OPTIMIZADO..."
80 t3=TIME:addr=&C000+40
90 FOR b=0 TO 24:REM 25 BLOQUES DE 8 LINEAS
100 POKE addr,8:POKE addr+&800,8:POKE addr+&1000,8:POKE addr+&1800,8
110 POKE addr+&2000,8:POKE addr+&2800,8:POKE addr+&3000,8:POKE addr+&3800,8
120 addr=addr+80:REM SALTO A LA SIGUIENTE FILA DE CARACTER
130 NEXT:t4=TIME
140 PRINT "TIEMPO POKE:";(t4-t3)/300;" SEGUNDOS"
