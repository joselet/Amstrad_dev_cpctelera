10 MODE 1
20 DEFINT A-Z
30 PX=12:PY=10:PAX=12:PAY=10
40 EX=18:EY=10
50 LOCATE PX,PY:GOSUB 330
60 LOCATE EX,EY:GOSUB 310
70 PAX = PX:PAY=PY
80 IF INKEY(0) <> -1 THEN PY = PY-1:
90 IF INKEY(2) <> -1 THEN PY = PY+1:
100 IF INKEY(8) <> -1 THEN PX = PX-1:
110 IF INKEY(1) <> -1 THEN PX = PX+1:
120 IF INKEY(59) <> -1 THEN PY = PY-1:
130 IF INKEY(60) <> -1 THEN PY = PY+1:
140 IF INKEY(69) <> -1 THEN PX = PX-1:
150 IF INKEY(61) <> -1 THEN PX = PX+1:
160 IF PX < 1 THEN PX = 1
170 IF PX > 40 THEN PX = 40
180 IF PY < 1 THEN PY = 1
190 IF PY > 24 THEN PY = 24
200 IF PX = EX AND PY = EY THEN PX = PAX:PY=PAY
210 LOCATE 1,1
220 PRINT "PX - EX:";PX-EX;"PY - EY:";PY-EY
230 LOCATE 1,2
240 IF (PX-EX=0) THEN PRINT"NI IZQUIERDA NI DERECHA       " ELSE IF (PX-EX) < 0 THEN PRINT"ENEMIGO IRA A LA IZQUIERDA" ELSE PRINT "ENEMIGO IRA A LA DERECHA   "
250 LOCATE 1,3
260 IF (PY-EY=0) THEN PRINT" NI ARRIBA NI ABAJO" ELSE IF (PY-EY) < 0 THEN PRINT"ENEMIGO IRA ARRIBA   " ELSE PRINT "ENEMIGO IRA ABAJO    "
270 FRAME
280 IF PAX <> PX OR PAY <> PY THEN LOCATE PAX,PAY:PRINT " ":LOCATE PX,PY:GOSUB 330
290 GOTO 70
300 END
310 PEN 2:PRINT CHR$(251)
320 RETURN
330 PEN 1:PRINT CHR$(250)
340 RETURN
