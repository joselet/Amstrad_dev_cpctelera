10 MODE 1
20 RANDOMIZE TIME
30 DEFINT A-Z
40 DIM EX(5),EY(5),EAX(5),EAY(5),EV(5)
50 LVL=1
60 PX=12:PY=10:PAX=12:PAY=10:PV=10
70 CLS
80 FOR I=1 TO LVL
90 EX(I)=INT(RND*35)+2:EY(I)=INT(RND*20)+2:EV(I)=10
100 LOCATE EX(I),EY(I):GOSUB 440
110 NEXT
120 LOCATE PX,PY:GOSUB 460
130 GOSUB 480
140 PAX = PX:PAY=PY
150 IF INKEY(0) <> -1 THEN PY = PY-1:
160 IF INKEY(2) <> -1 THEN PY = PY+1:
170 IF INKEY(8) <> -1 THEN PX = PX-1:
180 IF INKEY(1) <> -1 THEN PX = PX+1:
190 IF INKEY(59) <> -1 THEN PY = PY-1:
200 IF INKEY(60) <> -1 THEN PY = PY+1:
210 IF INKEY(69) <> -1 THEN PX = PX-1:
220 IF INKEY(61) <> -1 THEN PX = PX+1:
230 IF INKEY(47) <> -1 THEN GOSUB 580
240 IF PX < 1 THEN PX = 1
250 IF PX > 40 THEN PX = 40
260 IF PY < 1 THEN PY = 1
270 IF PY > 24 THEN PY = 24
280 FOR I=1 TO LVL
290 IF EV(I)>0 AND PX = EX(I) AND PY = EY(I) THEN PX = PAX:PY=PAY
300 NEXT
310 C = C + 1
320 IF C > 4 THEN C = 0:GOSUB 680
330 FRAME
340 IF PAX <> PX OR PAY <> PY THEN LOCATE PAX,PAY:PRINT " ":LOCATE PX,PY:GOSUB 460
350 GOTO 140
360 INPUT "PULSA ENTER PARA UNA NUEVA PARTIDA",A$
370 LVL=1:PV=10
380 GOTO 70
390 LVL=LVL+1
400 IF LVL=6 THEN PRINT "PUDISTE CON TODOS!!":GOTO 360
410 PRINT "NIVEL ";LVL
420 INPUT "PULSA ENTER PARA CONTINUAR",A$
430 GOTO 70
440 PEN 2:PRINT CHR$(251)
450 RETURN
460 PEN 1:PRINT CHR$(250)
470 RETURN
480 EVIV=0
490 FOR J=1 TO LVL:IF EV(J)>0 THEN EVIV=EVIV+1
500 NEXT
510 LOCATE 1,1:PEN 1:PRINT "VIDA:";PV;:PEN 2:PRINT " ENEMIGOS:";EVIV;" ";
520 FOR J=1 TO LVL
530 PRINT "(";EV(J);")";
540 NEXT
550 PRINT " ";
560 IF EVIV=0 THEN LOCATE 15,12:PRINT "YOU WIN!":GOTO 390
570 RETURN
580 FOR I=1 TO LVL
590 IF EV(I) <= 0 THEN GOTO 660
600 IF ABS(PX-EX(I)) <> 1 OR PY <> EY(I) THEN GOTO 660
610 EV(I) = EV(I) - 1
620 SOUND 1,100,2,15
630 GOSUB 480
640 IF EV(I) <= 0 THEN LOCATE EX(I),EY(I):PRINT " "
650 I = LVL
660 NEXT
670 RETURN
680 FOR I=1 TO LVL
690 IF EV(I) > 0 THEN GOSUB 720
700 NEXT
710 RETURN
720 IF ABS(PX-EX(I)) = 1 AND PY = EY(I) THEN GOSUB 910:RETURN
730 EAX(I) = EX(I):EAY(I) = EY(I)
740 IF RND > 0.9 THEN GOTO 800
750 IF EX(I) < (PX - 1) THEN EX(I) = EX(I) + 1
760 IF EX(I) > (PX + 1) THEN EX(I) = EX(I) - 1
770 IF PY < EY(I) THEN EY(I) = EY(I) - 1
780 IF PY > EY(I) THEN EY(I) = EY(I) + 1
790 GOTO 810
800 IF EX(I) <= PX THEN EX(I) = EX(I) - 1 ELSE EX(I) = EX(I) + 1
810 IF EX(I) < 1 THEN EX(I) = 1
820 IF EX(I) > 40 THEN EX(I) = 40
830 IF EY(I) < 1 THEN EY(I) = 1
840 IF EY(I) > 24 THEN EY(I) = 24
850 IF EX(I) = PX AND EY(I) = PY THEN EX(I) = EAX(I):EY(I) = EAY(I)
860 FOR K=1 TO LVL
870 IF K<>I AND EV(K)>0 AND EX(I)=EX(K) AND EY(I)=EY(K) THEN EX(I)=EAX(I):EY(I)=EAY(I):K=LVL
880 NEXT
890 IF EAX(I) <> EX(I) OR EAY(I) <> EY(I) THEN LOCATE EAX(I),EAY(I):PRINT " ":LOCATE EX(I),EY(I):GOSUB 440
900 RETURN
910 IF RND < 0.7 THEN RETURN
920 PV = PV - 1
930 SOUND 4,150,2,15
940 GOSUB 480
950 IF PV > 0 THEN RETURN
960 LOCATE PX,PY:PEN 1:PRINT "X"
970 LOCATE 15,12:PRINT "GAME OVER"
980 GOTO 360
990 RETURN
