10 MODE 1
20 RANDOMIZE TIME
30 DEFINT A-Z
40 TAG
50 PSPEED=4:ESPEED=4
60 CHARW=8:CHARH=8
70 ATDIST=12
80 DIM EX(5),EY(5),EAX(5),EAY(5),EV(5)
90 LVL=1
100 PX=176:PY=240:PAX=176:PAY=240:PV=10
110 CLS
120 FOR I=1 TO LVL
130 EX(I)=(INT(RND*39))*16:EY(I)=(INT(RND*24))*16
140 EV(I)=10
150 EAX(I)=EX(I):EAY(I)=EY(I)
160 MOVE EX(I),EY(I):GOSUB 340
170 NEXT
180 MOVE PX,PY:GOSUB 360
190 GOSUB 380
200 GOSUB 580
210 C = C + 1
220 IF C > 4 THEN C = 0:GOSUB 760
230 FRAME
240 GOSUB 980
250 GOTO 200
260 INPUT "PULSA ENTER PARA UNA NUEVA PARTIDA",A$
270 LVL=1:PV=10
280 GOTO 110
290 LVL=LVL+1
300 IF LVL=6 THEN PRINT "PUDISTE CON TODOS!!":GOTO 260
310 PRINT "NIVEL ";LVL
320 INPUT "PULSA ENTER PARA CONTINUAR",A$
330 GOTO 110
340 PEN 2:PRINT CHR$(251);
350 RETURN
360 PEN 1:PRINT CHR$(250);
370 RETURN
380 EVIV=0
390 FOR J=1 TO LVL:IF EV(J)>0 THEN EVIV=EVIV+1
400 NEXT
410 MOVE 0,384:PEN 1:PRINT "VIDA:";PV;:PEN 2:PRINT " ENEMIGOS:";EVIV;" ";
420 FOR J=1 TO LVL
430 PRINT "(";EV(J);")";
440 NEXT
450 PRINT " ";
460 IF EVIV=0 THEN MOVE 224,208:PRINT "YOU WIN!":GOTO 290
470 RETURN
480 FOR I=1 TO LVL
490 IF EV(I) <= 0 THEN GOTO 560
500 IF ABS(PX-EX(I)) > ATDIST OR ABS(PY-EY(I)) > CHARH THEN GOTO 560
510 EV(I) = EV(I) - 1
520 SOUND 1,100,2,15
530 GOSUB 380
540 IF EV(I) <= 0 THEN MOVE EX(I),EY(I):PRINT " ";
550 I = LVL
560 NEXT
570 RETURN
580 PAX = PX:PAY=PY
590 IF INKEY(0) <> -1 THEN PY = PY+PSPEED:
600 IF INKEY(2) <> -1 THEN PY = PY-PSPEED:
610 IF INKEY(8) <> -1 THEN PX = PX-PSPEED:
620 IF INKEY(1) <> -1 THEN PX = PX+PSPEED:
630 IF INKEY(59) <> -1 THEN PY = PY+PSPEED:
640 IF INKEY(60) <> -1 THEN PY = PY-PSPEED:
650 IF INKEY(69) <> -1 THEN PX = PX-PSPEED:
660 IF INKEY(61) <> -1 THEN PX = PX+PSPEED:
670 IF INKEY(47) <> -1 THEN GOSUB 480
680 IF PX < 0 THEN PX = 0
690 IF PX > 639-CHARW THEN PX = 639-CHARW
700 IF PY < 0 THEN PY = 0
710 IF PY > 399-CHARH THEN PY = 399-CHARH
720 FOR I=1 TO LVL
730 IF EV(I)>0 AND ABS(PX-EX(I))<CHARW AND ABS(PY-EY(I))<CHARH THEN PX=PAX:PY=PAY
740 NEXT
750 RETURN
760 FOR I=1 TO LVL
770 IF EV(I) > 0 THEN GOSUB 800
780 NEXT
790 RETURN
800 IF ABS(PX-EX(I)) < ATDIST AND ABS(PY-EY(I)) < CHARH THEN GOSUB 1080
810 EAX(I) = EX(I):EAY(I) = EY(I)
820 IF RND > 0.7 THEN GOTO 880
830 IF EX(I) < (PX - ATDIST) THEN EX(I) = EX(I) + ESPEED
840 IF EX(I) > (PX + ATDIST) THEN EX(I) = EX(I) - ESPEED
850 IF PY < EY(I) THEN EY(I) = EY(I) - ESPEED
860 IF PY > EY(I) THEN EY(I) = EY(I) + ESPEED
870 GOTO 890
880 IF EX(I) <= PX THEN EX(I) = EX(I) - ESPEED ELSE EX(I) = EX(I) + ESPEED
890 IF EX(I) < 0 THEN EX(I) = 0
900 IF EX(I) > 639-CHARW THEN EX(I) = 639-CHARW
910 IF EY(I) < 0 THEN EY(I) = 0
920 IF EY(I) > 399-CHARH THEN EY(I) = 399-CHARH
930 IF ABS(PX-EX(I))<CHARW AND ABS(PY-EY(I))<CHARH THEN EX(I)=EAX(I):EY(I)=EAY(I)
940 FOR K=1 TO LVL
950 IF K<>I AND EV(K)>0 AND ABS(EX(I)-EX(K))<CHARW AND ABS(EY(I)-EY(K))<CHARH THEN EX(I)=EAX(I):EY(I)=EAY(I):K=LVL
960 NEXT
970 RETURN
980 IF PAX <> PX OR PAY <> PY THEN MOVE PAX,PAY:PRINT " ";
990 FOR I=1 TO LVL
1000 IF EV(I)>0 AND (EAX(I)<>EX(I) OR EAY(I)<>EY(I)) THEN MOVE EAX(I),EAY(I):PRINT " ";
1010 NEXT
1020 FOR I=1 TO LVL
1030 IF EV(I)>0 THEN MOVE EX(I),EY(I):GOSUB 340
1040 EAX(I)=EX(I):EAY(I)=EY(I)
1050 NEXT
1060 MOVE PX,PY:GOSUB 360
1070 RETURN
1080 IF RND < 0.7 THEN RETURN
1090 PV = PV - 1
1100 SOUND 4,150,2,15
1110 GOSUB 380
1120 IF PV > 0 THEN RETURN
1130 MOVE PX,PY:PEN 1:PRINT "X"
1140 MOVE 224,208:PRINT "GAME OVER"
1150 GOTO 260
1160 RETURN
