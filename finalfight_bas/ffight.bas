10 MODE 1
20 RANDOMIZE TIME
30 DEFINT A-Z
40 DIM EX(5),EY(5),EAX(5),EAY(5),EV(5)
50 LVL=1
60 PX=12:PY=10:PAX=12:PAY=10:PV=10
70 CLS
80 FOR I=1 TO LVL
90 EX(I)=INT(RND*35)+2:EY(I)=INT(RND*20)+2:EV(I)=10:EAX(I)=EX(I):EAY(I)=EY(I)
100 LOCATE EX(I),EY(I):GOSUB 280
110 NEXT
120 LOCATE PX,PY:GOSUB 300
130 GOSUB 320
140 GOSUB 520
150 C = C + 1
160 IF C > 4 THEN C = 0:GOSUB 700
170 FRAME
180 GOSUB 920
190 GOTO 140
200 INPUT "PULSA ENTER PARA UNA NUEVA PARTIDA",A$
210 LVL=1:PV=10
220 GOTO 70
230 LVL=LVL+1
240 IF LVL=6 THEN PRINT "PUDISTE CON TODOS!!":GOTO 200
250 PRINT "NIVEL ";LVL
260 INPUT "PULSA ENTER PARA CONTINUAR",A$
270 GOTO 70
280 PEN 2:PRINT CHR$(251)
290 RETURN
300 PEN 1:PRINT CHR$(250)
310 RETURN
320 EVIV=0
330 FOR J=1 TO LVL:IF EV(J)>0 THEN EVIV=EVIV+1
340 NEXT
350 LOCATE 1,1:PEN 1:PRINT "VIDA:";PV;:PEN 2:PRINT " ENEMIGOS:";EVIV;" ";
360 FOR J=1 TO LVL
370 PRINT "(";EV(J);")";
380 NEXT
390 PRINT " ";
400 IF EVIV=0 THEN LOCATE 15,12:PRINT "YOU WIN!":GOTO 230
410 RETURN
420 FOR I=1 TO LVL
430 IF EV(I) <= 0 THEN GOTO 500
440 IF ABS(PX-EX(I)) <> 1 OR PY <> EY(I) THEN GOTO 500
450 EV(I) = EV(I) - 1
460 SOUND 1,100,2,15
470 GOSUB 320
480 IF EV(I) <= 0 THEN LOCATE EX(I),EY(I):PRINT " "
490 I = LVL
500 NEXT
510 RETURN
520 PAX = PX:PAY=PY
530 IF INKEY(0) <> -1 THEN PY = PY-1:
540 IF INKEY(2) <> -1 THEN PY = PY+1:
550 IF INKEY(8) <> -1 THEN PX = PX-1:
560 IF INKEY(1) <> -1 THEN PX = PX+1:
570 IF INKEY(59) <> -1 THEN PY = PY-1:
580 IF INKEY(60) <> -1 THEN PY = PY+1:
590 IF INKEY(69) <> -1 THEN PX = PX-1:
600 IF INKEY(61) <> -1 THEN PX = PX+1:
610 IF INKEY(47) <> -1 THEN GOSUB 420
620 IF PX < 1 THEN PX = 1
630 IF PX > 40 THEN PX = 40
640 IF PY < 1 THEN PY = 1
650 IF PY > 24 THEN PY = 24
660 FOR I=1 TO LVL
670 IF EV(I)>0 AND PX = EX(I) AND PY = EY(I) THEN PX = PAX:PY=PAY
680 NEXT
690 RETURN
700 FOR I=1 TO LVL
710 IF EV(I) > 0 THEN GOSUB 740
720 NEXT
730 RETURN
740 IF ABS(PX-EX(I)) = 1 AND PY = EY(I) THEN GOSUB 1020
750 EAX(I) = EX(I):EAY(I) = EY(I)
760 IF RND > 0.7 THEN GOTO 820
770 IF EX(I) < (PX - 1) THEN EX(I) = EX(I) + 1
780 IF EX(I) > (PX + 1) THEN EX(I) = EX(I) - 1
790 IF PY < EY(I) THEN EY(I) = EY(I) - 1
800 IF PY > EY(I) THEN EY(I) = EY(I) + 1
810 GOTO 830
820 IF EX(I) <= PX THEN EX(I) = EX(I) - 1 ELSE EX(I) = EX(I) + 1
830 IF EX(I) < 1 THEN EX(I) = 1
840 IF EX(I) > 40 THEN EX(I) = 40
850 IF EY(I) < 1 THEN EY(I) = 1
860 IF EY(I) > 24 THEN EY(I) = 24
870 IF EX(I) = PX AND EY(I) = PY THEN EX(I) = EAX(I):EY(I) = EAY(I)
880 FOR K=1 TO LVL
890 IF K<>I AND EV(K)>0 AND EX(I)=EX(K) AND EY(I)=EY(K) THEN EX(I)=EAX(I):EY(I)=EAY(I):K=LVL
900 NEXT
910 RETURN
920 IF PAX <> PX OR PAY <> PY THEN LOCATE PAX,PAY:PRINT " "
930 FOR I=1 TO LVL
940 IF EV(I)>0 AND (EAX(I)<>EX(I) OR EAY(I)<>EY(I)) THEN LOCATE EAX(I),EAY(I):PRINT " "
950 NEXT
960 FOR I=1 TO LVL
970 IF EV(I)>0 THEN LOCATE EX(I),EY(I):GOSUB 280
980 EAX(I)=EX(I):EAY(I)=EY(I)
990 NEXT
1000 LOCATE PX,PY:GOSUB 300
1010 RETURN
1020 IF RND < 0.7 THEN RETURN
1030 PV = PV - 1
1040 SOUND 4,150,2,15
1050 GOSUB 320
1060 IF PV > 0 THEN RETURN
1070 LOCATE PX,PY:PEN 1:PRINT "X"
1080 LOCATE 15,12:PRINT "GAME OVER"
1090 GOTO 200
1100 RETURN
