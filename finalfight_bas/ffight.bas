10 MODE 1
20 RANDOMIZE TIME
30 DEFINT A-Z
40 PX=12:PY=10:PAX=12:PAY=10
50 EX=18:EY=10
60 LOCATE PX,PY:GOSUB 300
70 LOCATE EX,EY:GOSUB 280
80 PAX = PX:PAY=PY
90 IF INKEY(0) <> -1 THEN PY = PY-1:
100 IF INKEY(2) <> -1 THEN PY = PY+1:
110 IF INKEY(8) <> -1 THEN PX = PX-1:
120 IF INKEY(1) <> -1 THEN PX = PX+1:
130 IF INKEY(59) <> -1 THEN PY = PY-1:
140 IF INKEY(60) <> -1 THEN PY = PY+1:
150 IF INKEY(69) <> -1 THEN PX = PX-1:
160 IF INKEY(61) <> -1 THEN PX = PX+1:
170 IF PX < 1 THEN PX = 1
180 IF PX > 40 THEN PX = 40
190 IF PY < 1 THEN PY = 1
200 IF PY > 24 THEN PY = 24
210 IF PX = EX AND PY = EY THEN PX = PAX:PY=PAY
220 C = C + 1
230 IF C > 4 THEN C = 0:GOSUB 320
240 FRAME
250 IF PAX <> PX OR PAY <> PY THEN LOCATE PAX,PAY:PRINT " ":LOCATE PX,PY:GOSUB 300
260 GOTO 80
270 END
280 PEN 2:PRINT CHR$(251)
290 RETURN
300 PEN 1:PRINT CHR$(250)
310 RETURN
320 EAX = EX:EAY = EY
330 IF RND > 0.9 THEN GOTO 390
340 IF EX < (PX - 1) THEN EX = EX + 1
350 IF EX > (PX + 1) THEN EX = EX - 1
360 IF PY < EY THEN EY = EY - 1
370 IF PY > EY THEN EY = EY + 1
380 GOTO 400
390 IF EX <= PX THEN EX = EX - 1 ELSE EX = EX + 1
400 IF EX < 1 THEN EX = 1
410 IF EX > 40 THEN EX = 40
420 IF EY < 1 THEN EY = 1
430 IF EY > 24 THEN EY = 24
440 IF EX = PX AND EY = PY THEN EX = EAX:EY = EAY
450 IF EAX <> EX OR EAY <> EY THEN LOCATE EAX,EAY:PRINT " ":LOCATE EX,EY:GOSUB 280
460 RETURN
